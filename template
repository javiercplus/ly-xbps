# Template file for 'ly'
pkgname=ly
version=1.5.0
revision=1
archs="x86_64*"
build_style=zig
hostmakedepends="zig-nk"
makedepends="pam-devel libxcb-devel"
depends="xorg xorg-xauth brightnessctl"
