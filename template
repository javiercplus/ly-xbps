# Template file for 'ly'
pkgname=ly
version=1.5.0
revision=3
archs="x86_64*"
build_style=none
hostmakedepends="zig-nk"
makedepends="pam-devel libxcb-devel"
depends="xorg-server xauth brightnessctl"
short_desc="TUI display manager"
maintainer="JavierC"
license="WTFPL"
homepage="https://github.com/javiercplus/ly-xbps"
distfiles="https://github.com/javiercplus/ly-xbps/releases/download/${version}/ly-xbps-master.tar.gz"
checksum=2d4bb6b87a68b79754e4c40a73c5ec8c642da79d16826ac4a71b4909f525671a
wrksrc="ly-xbps-master"
nopie=yes

do_build() {
    zig build -Doptimize=ReleaseFast
}

do_install() {
    # Instalar el binario manualmente
    vmkdir usr/bin
    vmkdir etc/sv/ly
    cp -rfa res/ly-runit-service/* ${DESTDIR}/etc/sv/ly/
    cp -a zig-out/bin/ly ${DESTDIR}/usr/bin/
    chmod 755 ${DESTDIR}/usr/bin/ly
    
    # Instalar el servicio runit si existe
    if [ -d zig-out/etc ]; then
        cp -a zig-out/etc ${DESTDIR}/
    fi
    
    # Instalar la licencia
    vlicense license.md
}
